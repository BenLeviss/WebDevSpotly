{
    "name": "spotly-server",
    "version": "1.0.0",
    "description": "Spotly backend API",
    "main": "dist/server.js",
    "scripts": {
        "dev": "nodemon src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "test": "tsc && jest --detectOpenHandles --forceExit",
        "test:watch": "jest --watch",
        "prod1": "tsc -p tsconfig_prod.json && node --env-file=.env.prod ./dist/server.js",
        "prod": "tsc -p tsconfig_prod.json && pm2 restart ecosystem.config.js --env production --env-file .envprod"
    },
    "dependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/jsonwebtoken": "^9.0.10",
        "axios": "^1.13.6",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "google-auth-library": "^10.6.2",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.0.1",
        "multer": "^2.1.1",
        "openai": "^6.34.0",
        "react-router-dom": "^7.13.1",
        "swagger-ui-express": "^5.0.1",
        "typescript": "^6.0.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.6.0",
        "@types/supertest": "^7.2.0",
        "@types/swagger-ui-express": "^4.1.8",
        "jest": "^30.3.0",
        "nodemon": "^3.1.11",
        "rimraf": "^6.1.2",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.9",
        "ts-node": "^10.9.2"
    }
}
